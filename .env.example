# app
NEXT_PUBLIC_APP_URL = "http://localhost:3000"
NEXT_PUBLIC_APP_NAME = "FlowDockr"
NEXT_PUBLIC_APP_DESCRIPTION = "Client Work OS for freelancers"
# search indexing switch:
# - "false": force noindex + block crawling
# - "true": force allow indexing
# - empty: auto (block preview/vercel.app, allow production custom domain)
NEXT_PUBLIC_ALLOW_INDEXING = ""

# theme
NEXT_PUBLIC_THEME = "default"

# appearance
NEXT_PUBLIC_APPEARANCE = "system"

# database
DATABASE_URL = ""
DATABASE_PROVIDER = "postgresql"
DB_SINGLETON_ENABLED = "true"

# auth secret
# openssl rand -base64 32
AUTH_SECRET = ""

# AI (Scope Guard MVP)
OPENAI_API_KEY = ""
SCOPE_GUARD_MODEL = "gpt-4.1-mini"
DEAL_STRATEGY_MODEL = "gpt-4.1-mini"
FLOWDOCKR_MODEL = "gpt-5-mini"

# Stripe (Flowdockr credits packs)
STRIPE_SECRET_KEY = ""
STRIPE_WEBHOOK_SECRET = ""
STRIPE_PRICE_STARTER_10 = ""
STRIPE_PRICE_PRO_50 = ""
STRIPE_PRICE_STUDIO_200 = ""
